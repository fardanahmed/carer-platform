---
import Layout from '../layouts/Layout.astro';
import { Card, CardHeader, CardTitle, CardContent } from '../components/ui/card';
import { Button } from '../components/ui/button';
import { Tabs, TabsList, TabsTrigger, TabsContent } from '../components/ui/tabs';
import { Users, GraduationCap, CheckCircle2, Clock } from 'lucide-react';
import { getCertifications, getSiteSettings } from '../lib/db-utils';
import { getImageUrl, images } from '../lib/images';
import type { MentorshipContent } from '../types';

const certifications = await getCertifications();
const mentorshipContent = await getSiteSettings<MentorshipContent>('mentorship_content');

const mentorshipImgUrl = getImageUrl(images.leadership); // fallback to leadership or R2 mentorship asset
---

<Layout title="Resources & Development">
  <!-- Header Section -->
  <section class="border-b border-border/50 py-20 sm:py-24 lg:py-28 bg-gradient-to-b from-slate-950/20 to-transparent">
    <div class="container mx-auto max-w-7xl px-6">
      <div class="max-w-3xl">
        <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-primary">Capacity Building</p>
        <h1 class="mb-6 font-heading text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl">
          Resources & <span class="bg-gradient-to-r from-primary to-blue-500 bg-clip-text text-transparent">Development</span>
        </h1>
        <p class="text-xl leading-relaxed text-muted-foreground font-light">
          Empowering the next generation of researchers, scientists, and engineers through certified training programs and structured mentorship.
        </p>
      </div>
    </div>
  </section>

  <!-- Interactive Content (Tabs) -->
  <section class="py-20">
    <div class="container mx-auto max-w-7xl px-6">
      <!-- client:load is critical for Radix tabs switching behavior -->
      <Tabs defaultValue="certifications" client:load className="w-full space-y-12">
        <div class="flex justify-center">
          <TabsList className="grid grid-cols-2 w-full max-w-md rounded-full bg-muted p-1 border border-border/50">
            <TabsTrigger value="certifications" className="rounded-full py-2.5 font-semibold text-base transition-all">
              Certifications
            </TabsTrigger>
            <TabsTrigger value="mentorship" className="rounded-full py-2.5 font-semibold text-base transition-all">
              Mentorship
            </TabsTrigger>
          </TabsList>
        </div>

        <!-- Certifications Tab -->
        <TabsContent value="certifications" className="animate-fade-in duration-300">
          <div class="grid gap-8 md:grid-cols-2 max-w-5xl mx-auto">
            {certifications.map((program) => (
              <Card className="group relative overflow-hidden border-border bg-card/45 backdrop-blur-md transition-all duration-300 hover:-translate-y-1 hover:shadow-xl hover:border-primary/50 hover:bg-card flex flex-col justify-between">
                <div class="absolute left-0 top-0 h-full w-1.5 bg-primary scale-y-0 transition-transform duration-300 group-hover:scale-y-100" />
                
                <CardHeader className="pb-4">
                  <div class="flex items-center justify-between gap-4 mb-4">
                    <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary/10 text-primary">
                      <GraduationCap class="h-6 w-6" />
                    </div>
                    <span class="inline-flex items-center gap-1.5 rounded-full bg-secondary text-secondary-foreground px-3 py-1 text-xs font-semibold">
                      <Clock class="h-3.5 w-3.5" />
                      {program.duration}
                    </span>
                  </div>
                  <CardTitle class="text-2xl font-bold tracking-tight text-foreground transition-colors duration-200 group-hover:text-primary">
                    {program.title}
                  </CardTitle>
                </CardHeader>
                
                <CardContent class="space-y-6">
                  <p class="text-muted-foreground leading-relaxed text-base">
                    {program.description}
                  </p>
                  <Button variant="outline" className="w-full rounded-xl font-semibold border-border bg-card group-hover:border-primary/50 group-hover:bg-primary group-hover:text-white transition-all">
                    View Program Details
                  </Button>
                </CardContent>
              </Card>
            ))}
          </div>
        </TabsContent>

        <!-- Mentorship Tab -->
        <TabsContent value="mentorship" className="animate-fade-in duration-300">
          {mentorshipContent && (
            <div class="grid gap-16 lg:grid-cols-2 lg:items-center max-w-6xl mx-auto">
              
              <!-- Mentorship Info -->
              <div class="space-y-8">
                <div class="space-y-4">
                  <h2 class="font-heading text-3xl font-extrabold tracking-tight sm:text-4xl text-foreground">
                    {mentorshipContent.title}
                  </h2>
                  <p class="text-lg text-muted-foreground leading-relaxed font-light">
                    {mentorshipContent.description}
                  </p>
                </div>
                
                <ul class="grid gap-4">
                  {mentorshipContent.benefits.map((benefit) => (
                    <li class="flex items-start gap-3.5">
                      <div class="mt-1 flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-primary/10 text-primary">
                        <CheckCircle2 class="h-4 w-4" />
                      </div>
                      <span class="text-base md:text-lg text-foreground/80 font-medium">
                        {benefit}
                      </span>
                    </li>
                  ))}
                </ul>
                
                <div class="pt-4">
                  <a 
                    href="/contact?subject=Mentorship%20Application"
                    class="inline-flex items-center justify-center rounded-full bg-primary px-8 py-4 text-base font-bold text-white shadow-xl shadow-primary/10 transition-all duration-300 hover:scale-105 hover:bg-primary/95"
                  >
                    Apply for Mentorship
                  </a>
                </div>
              </div>

              <!-- Mentorship Image Box -->
              <div class="relative">
                <div class="absolute -inset-1 bg-gradient-to-r from-primary to-blue-500 rounded-2xl blur opacity-15" />
                <div class="relative aspect-[4/3] md:aspect-[16/10] overflow-hidden rounded-2xl border border-border/50 shadow-2xl">
                  <img 
                    src={mentorshipImgUrl} 
                    alt="Research Mentorship Program" 
                    class="h-full w-full object-cover transition-transform duration-[8000ms] hover:scale-105" 
                  />
                </div>
              </div>

            </div>
          )}
        </TabsContent>
      </Tabs>
    </div>
  </section>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import ResourcesTabs from '../components/resources/ResourcesTabs';
import { getCertifications, getSiteSettings } from '../lib/db-utils';
import { getImageUrl, images } from '../lib/images';
import type { MentorshipContent } from '../types';

const certifications = await getCertifications();
const mentorshipContent = await getSiteSettings<MentorshipContent>('mentorship_content');

const mentorshipImgUrl = getImageUrl(images.leadership); // fallback to leadership or R2 mentorship asset
---

<Layout title="Resources & Development">
  <!-- Header Section -->
  <section class="border-b border-border/50 py-20 sm:py-24 lg:py-28 bg-gradient-to-b from-slate-950/20 to-transparent">
    <div class="container mx-auto max-w-7xl px-6">
      <div class="max-w-3xl">
        <p class="mb-4 text-sm font-semibold uppercase tracking-widest text-primary">Capacity Building</p>
        <h1 class="mb-6 font-heading text-4xl font-extrabold tracking-tight sm:text-5xl lg:text-6xl">
          Resources & <span class="bg-gradient-to-r from-primary to-blue-500 bg-clip-text text-transparent">Development</span>
        </h1>
        <p class="text-xl leading-relaxed text-muted-foreground font-light">
          Empowering the next generation of researchers, scientists, and engineers through certified training programs and structured mentorship.
        </p>
      </div>
    </div>
  </section>

  <!-- Interactive Content (Tabs) -->
  <section class="py-20">
    <div class="container mx-auto max-w-7xl px-6">
      <!-- client:load is critical for Radix tabs switching behavior -->
      <ResourcesTabs 
        client:load 
        certifications={certifications} 
        mentorshipContent={mentorshipContent} 
        mentorshipImgUrl={mentorshipImgUrl} 
      />
    </div>
  </section>
</Layout>

